{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/v2/crates/tauri-cli/schema.json",
  "productName": "FlyForge",
  "version": "0.2.0",
  "identifier": "com.flyforge.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FlyForge - 飞轮设计及运动学模拟",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 650,
        "maxWidth": 1920,
        "maxHeight": 1200,
        "resizable": true,
        "fullscreen": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
